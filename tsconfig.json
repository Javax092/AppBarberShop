{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true,
    "types": ["vite/client"]
  },
  "include": [
    "src/App.tsx",
    "src/main.tsx",
    "src/types/index.ts",
    "src/router/index.tsx",
    "src/lib/supabase.ts",
    "src/lib/auth.ts",
    "src/lib/agendamentos.ts",
    "src/lib/catalogo.ts",
    "src/lib/promocoes.ts",
    "src/lib/barbeiros.ts",
    "src/lib/horarios.ts",
    "src/hooks/useAuth.tsx",
    "src/hooks/useAgendamentos.ts",
    "src/hooks/useCatalogo.ts",
    "src/hooks/usePromocoes.ts",
    "src/hooks/useBarbeiros.ts",
    "src/hooks/useHorarios.ts",
    "src/components/**/*.tsx",
    "src/pages/public/**/*.tsx",
    "src/pages/admin/**/*.tsx",
    "src/pages/barbeiro/**/*.tsx"
  ],
  "references": []
}
